# ── Pixel Agents Multi-Server Nginx Configuration ─────────────────────
# Task 7.5: Load Balancing
#
# 使用方式：
#   1. 啟動多個 Pixel Agents 伺服器實例（不同端口或機器）
#      SERVER_ID=srv1 REDIS_URL=redis://localhost:6379 PORT=13001 node dist/index.js
#      SERVER_ID=srv2 REDIS_URL=redis://localhost:6379 PORT=13002 node dist/index.js
#   2. 複製此範例並調整 upstream 設定
#      cp nginx.conf.example /etc/nginx/conf.d/pixel-agents.conf
#   3. 重新載入 Nginx
#      nginx -t && nginx -s reload
#
# 前提條件：
#   - 所有伺服器實例共享相同的 Redis（REDIS_URL）
#   - 各實例使用唯一的 SERVER_ID
#   - Socket.IO Redis Adapter 已啟用（Phase 5 完成）

upstream pixel_agents_backend {
    # Sticky sessions：基於 IP 分配固定伺服器
    # Socket.IO 需要黏性會話確保 HTTP 輪詢升級 → WebSocket 落在同一伺服器
    ip_hash;

    server 127.0.0.1:13001;
    server 127.0.0.1:13002;
    # 可依需求新增更多實例：
    # server 127.0.0.1:13003;
    # server 192.168.1.100:13001;
}

# HTTP → HTTPS 重導向（選用）
# server {
#     listen 80;
#     server_name pixel-agents.example.com;
#     return 301 https://$host$request_uri;
# }

server {
    listen 80;
    # listen 443 ssl http2;
    server_name pixel-agents.example.com;

    # ── TLS 設定（啟用 HTTPS 時取消註解）──────────────────
    # ssl_certificate     /etc/letsencrypt/live/pixel-agents.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/pixel-agents.example.com/privkey.pem;
    # ssl_protocols       TLSv1.2 TLSv1.3;
    # ssl_ciphers         HIGH:!aNULL:!MD5;

    # ── 一般代理設定 ──────────────────────────────────────
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # ── 健康檢查端點（負載均衡器探針）──────────────────────
    location /health {
        proxy_pass http://pixel_agents_backend;
        proxy_connect_timeout 2s;
        proxy_read_timeout 5s;
    }

    # ── Socket.IO WebSocket 連線 ─────────────────────────
    # Socket.IO 路徑預設為 /socket.io/
    location /socket.io/ {
        proxy_pass http://pixel_agents_backend;

        # WebSocket 升級
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 較長的超時（WebSocket 為長連線）
        proxy_connect_timeout 7d;
        proxy_read_timeout    7d;
        proxy_send_timeout    7d;

        # 停用緩衝（即時推送）
        proxy_buffering off;
    }

    # ── Agent Node namespace WebSocket ────────────────────
    location /agent-node/ {
        proxy_pass http://pixel_agents_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 7d;
        proxy_read_timeout    7d;
        proxy_send_timeout    7d;
        proxy_buffering off;
    }

    # ── 終端 WebSocket ───────────────────────────────────
    location /terminal-ws {
        proxy_pass http://pixel_agents_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 7d;
        proxy_read_timeout    7d;
        proxy_send_timeout    7d;
        proxy_buffering off;
    }

    # ── API 路由 ──────────────────────────────────────────
    location /api/ {
        proxy_pass http://pixel_agents_backend;
        proxy_connect_timeout 10s;
        proxy_read_timeout 30s;
    }

    # ── 靜態檔案（客戶端 SPA）─────────────────────────────
    location / {
        proxy_pass http://pixel_agents_backend;
        proxy_connect_timeout 10s;
        proxy_read_timeout 30s;

        # 靜態資源快取（可選）
        # location ~* \.(js|css|png|jpg|ico|woff2?)$ {
        #     proxy_pass http://pixel_agents_backend;
        #     expires 7d;
        #     add_header Cache-Control "public, immutable";
        # }
    }
}

# ── 備註 ──────────────────────────────────────────────────────────
#
# Sticky Session 策略選擇：
# - ip_hash：基於客戶端 IP，最簡單但 NAT 後效果不佳
# - cookie（需 nginx-sticky-module）：
#     sticky cookie srv_id expires=1h domain=.example.com path=/;
# - Socket.IO sid 參數（需 lua 模組）：更精確但配置複雜
#
# 監控：
# - 每個實例暴露 /health 和 /api/metrics
# - 叢集狀態：GET /api/cluster/status
# - 使用 Prometheus + Grafana 收集指標（需額外中介軟體）
#
# 擴展建議：
# - 2-4 個實例適合中小規模使用
# - 每個實例約可支撐 50-100 個活躍代理
# - Redis 為瓶頸時考慮 Redis Cluster
